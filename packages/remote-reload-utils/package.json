{
  "name": "remote-reload-utils",
  "version": "0.0.8",
  "type": "module",
  "description": "Utilities for remote reload in Module Federation & React Component",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    }
  },
  "main": "./dist/main.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "loadRemote.md",
    "CHANGELOG.md"
  ],
  "gitRepository": {
    "type": "git",
    "url": "https://github.com/TaueFenCheng/react-mf-lib.git",
    "directory": "packages/remote-reload-utils"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "prepublishOnly": "npm run build",
    "format": "biome format --write",
    "check": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome format ./src --write",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:init": "zx scripts/initChangeset.mjs",
    "release:prepare": "zx scripts/generateReleasePr.mjs",
    "release:finalize": "zx scripts/finalizeRelease.mjs",
    "release:patch": "pnpm release:prepare -t patch",
    "release:minor": "pnpm release:prepare -t minor",
    "release:major": "pnpm release:prepare -t major",
    "publish:dry": "changeset publish --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.30.0",
    "@rslib/core": "0.17.0",
    "@types/node": "^22.17.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/ui": "^2.1.8",
    "base-biome-config": "0.0.8",
    "rsbuild-plugin-publint": "^0.3.3",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8",
    "zx": "^8.0.0"
  },
  "dependencies": {
    "@module-federation/enhanced": "0.18.3"
  }
}
