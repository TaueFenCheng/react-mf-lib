{
  "name": "react-mf-lib",
  "version": "0.0.15",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "check": "pnpm -r run check",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "add": "changeset add",
    "pre": "changeset pre",
    "status": "changeset status",
    "release": "./release.sh",
    "changeset:auto": "node scripts/auto-changeset.js",
    "build:react-adapter": "pnpm --filter react-adapter run build",
    "build:remote-reload-utils": "pnpm --filter remote-reload-utils run build",
    "build:test-mf-unpkg": "pnpm --filter test-mf-unpkg run build",
    "build:vue-adapter": "pnpm --filter vue-adapter run build",
    "dev:react-adapter": "pnpm --filter react-adapter run dev",
    "dev:remote-reload-utils": "pnpm --filter remote-reload-utils run dev",
    "dev:test-mf-unpkg": "pnpm --filter test-mf-unpkg run dev",
    "dev:vue-adapter": "pnpm --filter vue-adapter run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@changesets/cli": "^2.30.0",
    "@rsbuild/core": "^1.4.13",
    "@rslib/core": "0.17.0",
    "typescript": "^5.9.2"
  }
}
